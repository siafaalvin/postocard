# Hetzner Object Storage (S3-compatible)
S3_ENDPOINT="https://<bucket>.your-objectstorage.com"
S3_BUCKET="postocard-media"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="eu-central-1"

# MapLibre tile style — OpenFreeMap (free, no account/key needed)
# Options: bright, positron, fiord-color — see openfreemap.org
NEXT_PUBLIC_MAP_STYLE_URL="https://tiles.openfreemap.org/styles/bright"

# Top Feed cron authentication
CRON_SECRET=""

# Dev only: set to "true" to skip Stripe payment on registration
SKIP_PAYMENT_GATE="false"
