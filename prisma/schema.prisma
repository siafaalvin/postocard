generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum UserVisibility {
  public
  private
}

enum UserTier {
  guest
  basic
  plus
  creator
  moderator
  admin
}

enum PostType {
  image
  video
  status
}

enum PostVisibility {
  public
  followers
  following
  mentioned
}

enum NotificationType {
  new_follower
  post_liked
  post_commented
  comment_replied
}

enum FollowStatus {
  active
  pending
}

enum EventType {
  followed
  unfollowed
  follow_requested
  muted
  blocked
  liked_post
}

// ─────────────────────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  username        String         @unique @db.VarChar(30)
  displayName     String         @db.VarChar(50)
  avatarUrl       String?
  bio             String?        @db.VarChar(500)
  zipCode         String?        @db.VarChar(10)
  konvoId         String?
  visibility      UserVisibility @default(public)
  tier            UserTier       @default(basic)
  firstName       String?
  lastName        String?
  phoneNumber     String?
  phoneVerifiedAt DateTime?
  cameraOnlyMode  Boolean        @default(false)
  statusOnlyMode  Boolean        @default(false)
  registrationPaidAt DateTime?
  renewalDueAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Posts & interactions
  posts           Post[]
  likes           Like[]
  comments        Comment[]
  replies         Reply[]
  commentLikes    CommentLike[]

  // Social graph
  following       Follow[]       @relation("Follower")  // people this user follows
  followers       Follow[]       @relation("Following") // people who follow this user
  muting          Mute[]         @relation("Muter")
  mutedBy         Mute[]         @relation("Muted")
  blocking        Block[]        @relation("Blocker")
  blockedBy       Block[]        @relation("Blocked")

  // Calendar
  userEvents      UserEvent[]    @relation("EventOwner")
  targetEvents    UserEvent[]    @relation("EventTarget")

  // Feed cap tracking
  feedDailyCounts FeedDailyCount[]

  // View extensions (F1)
  viewExtensions  ViewExtension[]

  // Temporary profile grants (F2)
  grantsGiven     TemporaryProfileGrant[] @relation("GrantsGiven")
  grantsReceived  TemporaryProfileGrant[] @relation("GrantsReceived")

  // Block lists (F6)
  blockLists      BlockList[]
  blockListEntries BlockListEntry[] @relation("BlockListEntries")

  // Flagging (F8)
  flagsPlaced   UserFlag[] @relation("FlagPlacer")
  flagsReceived UserFlag[] @relation("FlaggedUser")
  publicFlags   PublicFlag[]

  // Post mentions
  mentionedIn   PostMention[]

  // Notifications
  notificationsReceived Notification[] @relation("NotificationsReceived")
  notificationsActed    Notification[] @relation("NotificationsActed")

  // Alternate display names (Plus: 1, Creator: 2)
  alternateNames  UserDisplayName[]

  // Vouch system
  vouchesGiven  Vouch[] @relation("UserVouches")
  vouchReceived Vouch?  @relation("UserVouched")

  // Username challenges
  challenges  UsernameChallenge[]

  // Ad Folder
  ads  AdDelivery[]

  // Local feeds
  savedLocationFeeds  SavedLocationFeed[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Post
// ─────────────────────────────────────────────────────────────────────────────

model Post {
  id            String         @id @default(cuid())
  authorId      String
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type          PostType
  mediaKey      String?                          // S3 object key; null for status posts
  caption       String?        @db.VarChar(2200)
  lat           Float?
  lng           Float?
  visibility    PostVisibility @default(public)
  likeCount     Int            @default(0)
  mediaMetadata Json?                            // raw EXIF fields extracted client-side (F7)
  hasCamera     Boolean        @default(false)   // true when EXIF Make+Model present (F7)
  createdAt     DateTime       @default(now())
  deletedAt     DateTime?

  likes         Like[]
  comments      Comment[]
  userEvents    UserEvent[]
  mentions      PostMention[]
  notifications Notification[]

  @@index([authorId, createdAt])
  @@index([createdAt])
  @@index([lat, lng])
  @@index([hasCamera])
}

// ─────────────────────────────────────────────────────────────────────────────
// Like
// ─────────────────────────────────────────────────────────────────────────────

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Comment
// ─────────────────────────────────────────────────────────────────────────────

model Comment {
  id               String    @id @default(cuid())
  postId           String
  post             Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId         String
  author           User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body             String    @db.VarChar(2200)
  commentLikeCount Int       @default(0)
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?

  replies          Reply[]
  commentLikes     CommentLike[]
  grants           TemporaryProfileGrant[]  // grants triggered by this comment (F2)
  notifications    Notification[]

  @@index([postId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// Reply (F3 — one level deep only)
// ─────────────────────────────────────────────────────────────────────────────

model Reply {
  id        String    @id @default(cuid())
  commentId String
  comment   Comment   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String    @db.VarChar(2200)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  grants        TemporaryProfileGrant[]  // grants triggered by this reply (F2)
  notifications Notification[]

  @@index([commentId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CommentLike (F4 — needed for mass-block by comment likers)
// ─────────────────────────────────────────────────────────────────────────────

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Follow
// ─────────────────────────────────────────────────────────────────────────────

model Follow {
  id          String       @id @default(cuid())
  followerId  String
  follower    User         @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User         @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  status      FollowStatus @default(active)
  createdAt   DateTime     @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Mute — F5: adds context fields
// ─────────────────────────────────────────────────────────────────────────────

model Mute {
  id              String   @id @default(cuid())
  muterId         String
  muter           User     @relation("Muter", fields: [muterId], references: [id], onDelete: Cascade)
  mutedId         String
  muted           User     @relation("Muted", fields: [mutedId], references: [id], onDelete: Cascade)
  contextNote     String?  @db.VarChar(200)
  contextHashtag  String?  @db.VarChar(100)
  visibleToTarget Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([muterId, mutedId])
  @@index([muterId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Block — F5: adds context fields
// ─────────────────────────────────────────────────────────────────────────────

model Block {
  id              String   @id @default(cuid())
  blockerId       String
  blocker         User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId       String
  blocked         User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  contextNote     String?  @db.VarChar(200)
  contextHashtag  String?  @db.VarChar(100)
  visibleToTarget Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// UserEvent — calendar interaction log
// ─────────────────────────────────────────────────────────────────────────────

model UserEvent {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation("EventOwner", fields: [userId], references: [id], onDelete: Cascade)
  eventType    EventType
  targetUserId String?
  targetUser   User?     @relation("EventTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPostId String?
  targetPost   Post?     @relation(fields: [targetPostId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// FeedDailyCount — daily post-view tracking for cap enforcement
// ─────────────────────────────────────────────────────────────────────────────

model FeedDailyCount {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date    DateTime @db.Date
  count   Int      @default(0)

  @@unique([userId, date])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// TopFeedSnapshot — hourly computed list of top-100 post IDs
// ─────────────────────────────────────────────────────────────────────────────

model TopFeedSnapshot {
  id          String   @id @default(cuid())
  computedAt  DateTime @default(now())
  postIds     Json     // ordered array of Post IDs

  @@index([computedAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ViewExtension (F1) — $1 / 200 extra posts / 7 days
// ─────────────────────────────────────────────────────────────────────────────

model ViewExtension {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String   @unique
  postsGranted          Int      @default(200)
  usedCount             Int      @default(0)
  expiresAt             DateTime
  createdAt             DateTime @default(now())

  @@index([userId, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// TemporaryProfileGrant (F2) — time-limited profile visibility for private users
// ─────────────────────────────────────────────────────────────────────────────

model TemporaryProfileGrant {
  id               String   @id @default(cuid())
  grantedById      String                          // the private user whose profile becomes visible
  grantedBy        User     @relation("GrantsGiven", fields: [grantedById], references: [id], onDelete: Cascade)
  grantedToId      String                          // the user who can now view that profile
  grantedTo        User     @relation("GrantsReceived", fields: [grantedToId], references: [id], onDelete: Cascade)
  triggerCommentId String?
  triggerComment   Comment? @relation(fields: [triggerCommentId], references: [id], onDelete: SetNull)
  triggerReplyId   String?
  triggerReply     Reply?   @relation(fields: [triggerReplyId], references: [id], onDelete: SetNull)
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@unique([grantedById, grantedToId])
  @@index([grantedToId, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// BlockList + BlockListEntry (F6) — shareable block lists
// ─────────────────────────────────────────────────────────────────────────────

model BlockList {
  id          String           @id @default(cuid())
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String           @db.VarChar(100)
  slug        String           @unique         // 12-char random token for shareable URL
  isPublic    Boolean          @default(true)
  importCount Int              @default(0)
  entries     BlockListEntry[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([ownerId])
}

model BlockListEntry {
  id            String    @id @default(cuid())
  blockListId   String
  blockList     BlockList @relation(fields: [blockListId], references: [id], onDelete: Cascade)
  blockedUserId String
  blockedUser   User      @relation("BlockListEntries", fields: [blockedUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime  @default(now())

  @@unique([blockListId, blockedUserId])
  @@index([blockListId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Flagging (F8) — personal + public threshold flags
// ─────────────────────────────────────────────────────────────────────────────

enum FlagType {
  red
}

model FlagAttribute {
  id          String     @id @default(cuid())
  label       String
  category    String
  type        FlagType   @default(red)
  flags       UserFlag[]
  publicFlags PublicFlag[]

  @@index([category])
}

// One personal flag per (placer, flaggedUser, attribute) triple
model UserFlag {
  id            String        @id @default(cuid())
  placerId      String
  placer        User          @relation("FlagPlacer",  fields: [placerId],      references: [id], onDelete: Cascade)
  flaggedUserId String
  flaggedUser   User          @relation("FlaggedUser", fields: [flaggedUserId], references: [id], onDelete: Cascade)
  attributeId   String
  attribute     FlagAttribute @relation(fields: [attributeId], references: [id])
  note          String?       @db.VarChar(100)
  createdAt     DateTime      @default(now())

  @@unique([placerId, flaggedUserId, attributeId])
  @@index([flaggedUserId])
}

// Aggregate: one row per (flaggedUser, attribute); becomes public when flagCount >= 10
model PublicFlag {
  id            String               @id @default(cuid())
  flaggedUserId String
  flaggedUser   User                 @relation(fields: [flaggedUserId], references: [id], onDelete: Cascade)
  attributeId   String
  attribute     FlagAttribute        @relation(fields: [attributeId], references: [id])
  flagCount     Int                  @default(0)
  isActive      Boolean              @default(false) // true when flagCount >= 10; false after paid removal
  removalCount  Int                  @default(0)     // increments each time flaggedUser pays to remove
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  payments      FlagRemovalPayment[]

  @@unique([flaggedUserId, attributeId])
  @@index([flaggedUserId])
}

// Stripe payment record for each public-flag removal
model FlagRemovalPayment {
  id                    String     @id @default(cuid())
  publicFlagId          String
  publicFlag            PublicFlag @relation(fields: [publicFlagId], references: [id])
  stripePaymentIntentId String     @unique
  amountCents           Int        // 100 | 1000 | 10000 | 100000
  offenseNumber         Int        // 1–4
  paidAt                DateTime   @default(now())
}

// ─────────────────────────────────────────────────────────────────────────────
// PostMention — explicit mention list for visibility: mentioned posts
// ─────────────────────────────────────────────────────────────────────────────

model PostMention {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Notification — activity feed entries
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   User             @relation("NotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String
  actor       User             @relation("NotificationsActed", fields: [actorId], references: [id], onDelete: Cascade)
  type        NotificationType
  postId      String?
  post        Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  commentId   String?
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)
  replyId     String?
  reply       Reply?           @relation(fields: [replyId], references: [id], onDelete: SetNull)
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, read, createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// UserDisplayName — saved alternate display names (Plus: slot 1, Creator: slots 1-2)
// ─────────────────────────────────────────────────────────────────────────────

model UserDisplayName {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(50)
  slot      Int
  createdAt DateTime @default(now())

  @@unique([userId, slot])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Vouch — existing user vouching for a new registrant
// ─────────────────────────────────────────────────────────────────────────────

model Vouch {
  id        String   @id @default(cuid())
  voucherId String
  voucher   User     @relation("UserVouches", fields: [voucherId], references: [id])
  newUserId String   @unique
  newUser   User     @relation("UserVouched", fields: [newUserId], references: [id])
  createdAt DateTime @default(now())

  @@unique([voucherId, newUserId])
}

// ─────────────────────────────────────────────────────────────────────────────
// UsernameChallenge — dispute over a username taken by an earlier registrant
// ─────────────────────────────────────────────────────────────────────────────

model UsernameChallenge {
  id           String   @id @default(cuid())
  username     String
  challengerId String?
  challenger   User?    @relation(fields: [challengerId], references: [id], onDelete: SetNull)
  evidence     String   @db.VarChar(1000)
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  @@index([username])
  @@index([challengerId])
}

// ─────────────────────────────────────────────────────────────────────────────
// SavedLocationFeed — named location feeds saved by Plus/Creator users
// ─────────────────────────────────────────────────────────────────────────────

model SavedLocationFeed {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @db.VarChar(100)
  lat       Float
  lng       Float
  radiusKm  Float    @default(25)
  slot      Int
  createdAt DateTime @default(now())

  @@unique([userId, slot])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AdDelivery — ads pushed from BubblAds network into the user's Ad Folder
// ─────────────────────────────────────────────────────────────────────────────

model AdDelivery {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String    @db.VarChar(200)
  body       String    @db.VarChar(2000)
  ctaUrl     String?
  imageUrl   String?
  source     String    @default("bubblads")
  read       Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, read, createdAt])
}
